generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id              String         @id
  displayName     String?
  timezone        String         @default("UTC")
  onboardingDone  Boolean        @default(false)
  waterGoalMl     Int            @default(2000)
  movementGoalMin Int            @default(30)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  email           String         @unique
  dailyCheckIns   DailyCheckIn[]
  dailyNotes      DailyNote[]
  habits          Habit[]
  habitEntries    HabitEntry[]
  weeklyReviews   WeeklyReview[]
}

model Habit {
  id         String         @id @default(cuid())
  profileId  String
  name       String
  category   HabitCategory  @default(CUSTOM)
  frequency  HabitFrequency @default(DAILY)
  targetDays Int?
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  archivedAt DateTime?
  profile    Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  entries    HabitEntry[]

  @@index([profileId])
}

model HabitEntry {
  id        String   @id @default(cuid())
  profileId String
  habitId   String
  date      DateTime
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([profileId, date])
}

model DailyCheckIn {
  id                String   @id @default(cuid())
  profileId         String
  date              DateTime
  moodScore         Int
  energyScore       Int
  sleepQualityScore Int
  stressScore       Int?
  waterMl           Int?
  movementMin       Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  profile           Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, date])
  @@index([profileId, date])
}

model DailyNote {
  id        String   @id @default(cuid())
  profileId String
  date      DateTime
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, date])
  @@index([profileId, date])
}

model WeeklyReview {
  id            String   @id @default(cuid())
  profileId     String
  weekStart     DateTime
  wins          String?
  challenges    String?
  nextWeekFocus String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, weekStart])
  @@index([profileId, weekStart])
}

enum HabitCategory {
  MOVEMENT
  HYDRATION
  SLEEP
  MINDFULNESS
  NUTRITION
  RECOVERY
  CUSTOM
}

enum HabitFrequency {
  DAILY
  WEEKDAYS
  CUSTOM
}
